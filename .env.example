APP_NAME=TrustRAG API
APP_ENV=local
LOG_LEVEL=INFO
CHUNK_SIZE=800
CHUNK_OVERLAP=120
INGEST_RATE_LIMIT_PER_MINUTE=10

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
